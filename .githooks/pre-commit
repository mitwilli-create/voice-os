#!/bin/sh
# Privacy gate: refuse to commit raw corpus or personal-data files.
# Enable once per clone with: git config core.hooksPath .githooks

fail=0
for f in $(git diff --cached --name-only --diff-filter=ACM); do
    case "$f" in
        corpus/*|sources/*|*.jsonl|*.mbox|ingest.local.json)
            echo "pre-commit: BLOCKED personal-data path: $f" >&2
            fail=1
            continue
            ;;
    esac
    case "$f" in
        tests/fixtures/*) continue ;;
    esac
    size=$(git cat-file -s ":$f" 2>/dev/null || echo 0)
    if [ "$size" -gt 1048576 ]; then
        echo "pre-commit: BLOCKED file over 1MB (likely corpus data): $f" >&2
        fail=1
    fi
done

if [ "$fail" -ne 0 ]; then
    echo "pre-commit: raw voice-corpus data must never be committed." >&2
    echo "pre-commit: if a blocked file is genuinely safe, commit with --no-verify." >&2
    exit 1
fi
exit 0
